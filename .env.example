# AI Backend API — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Nested settings use __ as delimiter.
# Example: OPENAI__API_KEY maps to settings.openai.api_key

# ── Application ──────────────────────────────────────────────
APP_NAME=AI Backend API
DEBUG=false
LOG_LEVEL=INFO

# ── API Authentication (Master Key) ──────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production (startup will reject the default below)
API_KEY=change-me-in-production

# ── OpenAI ───────────────────────────────────────────────────
OPENAI__API_KEY=sk-your-openai-key-here
OPENAI__MODEL=gpt-4o
OPENAI__EMBEDDING_MODEL=text-embedding-3-small
OPENAI__MAX_RETRIES=3
OPENAI__EMBEDDING_DIMENSIONS=1536
OPENAI__MAX_TOKENS=4096
OPENAI__TEMPERATURE=0.7

# ── PostgreSQL ───────────────────────────────────────────────
# Run: psql -U postgres < scripts/migrate.sql  (first time)
DATABASE__HOST=localhost
DATABASE__PORT=5432
DATABASE__USER=postgres
DATABASE__PASSWORD=postgres
DATABASE__DB_NAME=ai_backend
DATABASE__POOL_MIN_SIZE=2
DATABASE__POOL_MAX_SIZE=10

# ── Redis (Cache + Rate Limit + ARQ Queue) ───────────────────
REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__DB=0
# REDIS__PASSWORD=your-redis-password

# ── Qdrant ───────────────────────────────────────────────────
QDRANT__HOST=localhost
QDRANT__PORT=6333
QDRANT__GRPC_PORT=6334
QDRANT__COLLECTION_NAME=documents
QDRANT__PREFER_GRPC=false

# ── Chunking (in TOKENS, not characters) ─────────────────────
CHUNKING__CHUNK_SIZE=512
CHUNKING__CHUNK_OVERLAP=50

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT__REQUESTS_PER_MINUTE=60
RATE_LIMIT__BURST_SIZE=10

# ── ARQ Worker ───────────────────────────────────────────────
# Start: arq app.infrastructure.queue.arq_worker.ArqWorkerSettings
WORKER__MAX_JOBS=10
WORKER__JOB_TIMEOUT=300
WORKER__MAX_RETRIES=3
WORKER__RETRY_DELAY=30

# ── RAG Quality ──────────────────────────────────────────────
RAG__SCORE_THRESHOLD=0.72
RAG__MAX_CONTEXT_TOKENS=20000
RAG__TOP_K=10
